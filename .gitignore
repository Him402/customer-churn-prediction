# ── Model file ───────────────────────────────────────────────────────────────
# Regenerated by running the training notebook — do not commit binary pkl files.
# They are large, not human-readable, and version-specific to the sklearn that
# saved them (committing them causes the exact monotonic_cst error this project
# spent time debugging).
churn_best_pipeline.pkl

# ── Dataset ──────────────────────────────────────────────────────────────────
# The raw data file is downloaded from Kaggle by the user — see README.md.
# Never commit datasets to Git: they bloat the repo history permanently.
*.csv

# ── Virtual environment ───────────────────────────────────────────────────────
# The churn_env/ folder contains thousands of installed package files.
# Anyone cloning the repo recreates it using: pip install -r requirements.txt
churn_env/
venv/
env/
.venv/

# ── Python cache files ────────────────────────────────────────────────────────
# These are auto-generated bytecode files that Python creates for speed.
# They are machine-specific and should never be version-controlled.
__pycache__/
*.py[cod]
*.pyo

# ── Jupyter Notebook checkpoints ─────────────────────────────────────────────
# Jupyter auto-saves checkpoints into this hidden folder. They are temporary
# working copies, not part of the project itself.
.ipynb_checkpoints/

# ── OS-generated files ────────────────────────────────────────────────────────
# These are created automatically by macOS, Windows, or Linux file explorers.
# They have no relevance to the project and clutter the repo for other users.
.DS_Store
Thumbs.db
desktop.ini

# ── IDE and editor settings ───────────────────────────────────────────────────
# These folders contain your personal editor configuration — another developer
# may use a completely different editor, so these should not be shared.
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
